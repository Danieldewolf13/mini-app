<section class="panel">
  <div class="section-head">
    <div>
      <p class="section-kicker">Planning</p>
      <h2>Appointments</h2>
    </div>
  </div>

  <div class="appointment-list">
    <% if (appointments.length) { %>
      <% appointments.forEach((appt) => { %>
        <article class="appointment-card">
          <strong>#<%= appt.id %> · <%= appt.scheduled_at_label %></strong>
          <p><%= appt.client_name || "-" %></p>
          <p class="muted"><%= appt.technician_name || "Unassigned" %></p>
        </article>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Geen afspraken in de komende twee dagen.</p>
    <% } %>
  </div>
</section>
