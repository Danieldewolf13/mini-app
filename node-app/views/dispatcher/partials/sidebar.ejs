<nav class="nav">
  <% navigation.forEach((item) => { %>
    <a
      href="<%= item.href %>"
      class="nav-link <%= activeNav === item.key ? "is-active" : "" %>"
      title="<%= item.label %>"
      aria-label="<%= item.label %>"
    >
      <span class="nav-link-short"><%= item.label.slice(0, 1) %></span>
      <span class="nav-link-label"><%= item.label %></span>
    </a>
  <% }) %>
</nav>
