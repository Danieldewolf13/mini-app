<div class="topbar-inner">
  <div class="topbar-copy topbar-copy--compact">
    <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle navigation" aria-expanded="true">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <h1><%= pageTitle %></h1>
  </div>

  <div class="topbar-tools">
    <input class="search" id="global-search" placeholder="Search jobs..." />
    <% if (currentUser) { %>
      <div class="current-user-chip">
        <strong><%= currentUser.name %></strong>
        <span><%= currentUser.role %></span>
      </div>
    <% } %>
    <div class="actions">
      <% actions.forEach((action) => { %>
        <a
          href="<%= action.href %>"
          class="topbar-button <%= action.variant === 'primary' ? 'is-primary' : '' %>"
          <%= action.external ? 'target="_blank" rel="noreferrer"' : '' %>
        ><%= action.label %></a>
      <% }) %>
      <% if (currentUser) { %>
        <form method="post" action="/logout" class="logout-form">
          <button type="submit" class="topbar-button">Logout</button>
        </form>
      <% } %>
    </div>
  </div>
</div>
