<section class="panel jobs-panel">
  <div class="section-head">
    <div>
      <p class="section-kicker"><%= t("dashboard.jobs.kicker", "Jobs") %></p>
      <h2><%= t("dashboard.jobs.title", "Active jobs") %></h2>
    </div>
    <a class="section-link" href="/dispatcher/jobs"><%= t("common.view_all", "View all") %></a>
  </div>

  <p class="section-meta" data-visible-count>Main operational list for current dispatcher decisions.</p>

  <div class="jobs-list jobs-preview">
    <% if (jobs.length) { %>
      <% jobs.slice(0, 8).forEach((job) => { %>
        <%- include("job_card", { job }) %>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Nog geen actieve jobs gevonden.</p>
    <% } %>
  </div>
</section>
