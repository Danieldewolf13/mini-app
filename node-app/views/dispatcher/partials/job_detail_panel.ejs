<div class="job-detail hidden" id="jobDetail">
  <div class="detail-header">
    <div>
      <p class="section-kicker">Job detail</p>
      <h2 id="jobDetailTitle">Select a job</h2>
    </div>
  </div>

  <div class="section">
    <h3>Overview</h3>
    <div id="jobOverview" class="detail-stack">
      <p class="muted">Kies een job om details te tonen.</p>
    </div>
  </div>

  <div class="section">
    <h3>Actions</h3>
    <div class="detail-actions">
      <button id="assignBtn" type="button">Assign</button>
      <button id="statusBtn" type="button">Change status</button>
    </div>
  </div>

  <div class="section">
    <h3>Documents</h3>
    <div id="jobDocs" class="detail-stack">
      <p class="muted">Nog geen documenten gekoppeld.</p>
    </div>
  </div>

  <div class="section">
    <h3>Finance</h3>
    <div id="jobFinance" class="detail-stack">
      <p class="muted">Nog geen job geselecteerd.</p>
    </div>
  </div>
</div>
