<section class="panel planning-board">
  <div class="section-head">
    <div>
      <p class="section-kicker"><%= t("planning.board.kicker", "Planning") %></p>
      <h2><%= t("planning.board.title", "Dispatcher screen") %></h2>
    </div>
    <span class="section-meta" id="planningViewLabel"><%= t("planning.board.day_view", "Day view") %></span>
  </div>

  <div id="planningWeekPlaceholder" class="planning-week-placeholder hidden"></div>

  <div id="planningDayView" class="planning-day-view">
    <div class="planning-layout">
      <div id="planningTimeSidebar" class="planning-time-sidebar"></div>
      <div class="planning-main" id="planningMain">
        <div id="planningHeaderTechnicians" class="planning-header-technicians"></div>
        <div id="planningGrid" class="planning-grid"></div>
      </div>
    </div>
  </div>
</section>
