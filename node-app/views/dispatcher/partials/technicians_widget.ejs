<section class="panel technicians-panel">
  <div class="section-head">
    <div>
      <p class="section-kicker"><%= t("dashboard.technicians.kicker", "Crew") %></p>
      <h2><%= t("dashboard.technicians.title", "Technicians") %></h2>
    </div>
    <a class="section-link" href="/dispatcher/technicians"><%= t("common.view_all", "View all") %></a>
  </div>

  <p class="section-meta">Who is free right now and who already has active work.</p>

  <div class="tech-list tech-preview">
    <% if (technicians.length) { %>
      <% technicians.slice(0, 6).forEach((tech) => { %>
        <div class="tech-card <%= Number(tech.active_jobs) === 0 ? 'free' : 'busy' %>">
          <div><%= tech.full_name %></div>
          <div><%= Number(tech.active_jobs) === 0 ? "Free" : `${tech.active_jobs} active` %></div>
          <div><%= tech.tech_key || tech.role %></div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Nog geen techniekers gevonden.</p>
    <% } %>
  </div>
</section>
