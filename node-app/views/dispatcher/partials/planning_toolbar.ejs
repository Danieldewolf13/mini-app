<section class="panel planning-toolbar">
  <div class="planning-toolbar-group">
    <button class="toolbar-btn" id="planningTodayBtn" type="button"><%= t("planning.toolbar.today", "Today") %></button>
    <button class="toolbar-btn" id="planningPrevBtn" type="button"><%= t("planning.toolbar.prev", "Prev") %></button>
    <button class="toolbar-btn" id="planningNextBtn" type="button"><%= t("planning.toolbar.next", "Next") %></button>
  </div>

  <div class="planning-toolbar-group">
    <input id="planningDate" type="date" value="<%= planning_date %>">
    <div class="view-switch">
      <button class="toolbar-btn is-active" data-view-switch="day" type="button"><%= t("planning.toolbar.day", "Day") %></button>
      <button class="toolbar-btn" data-view-switch="week" type="button"><%= t("planning.toolbar.week", "Week") %></button>
    </div>
  </div>

  <div class="planning-toolbar-group">
    <select id="planningTechnicianFilter">
      <option value=""><%= t("planning.toolbar.all_technicians", "All technicians") %></option>
    </select>
    <select id="planningRegionFilter">
      <option value=""><%= t("planning.toolbar.all_regions", "All regions") %></option>
    </select>
  </div>
</section>
