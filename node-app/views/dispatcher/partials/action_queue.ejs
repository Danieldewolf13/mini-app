<section class="panel queue queue-panel">
  <div class="section-head">
    <div>
      <p class="section-kicker"><%= t("dashboard.queue.kicker", "Queue") %></p>
      <h2><%= t("dashboard.queue.title", "Needs attention") %></h2>
    </div>
  </div>

  <div class="queue-preview">
  <div class="queue-block">
    <h3><%= t("dashboard.queue.unassigned", "Unassigned") %></h3>
    <% if (queue.unassigned.length) { %>
      <% queue.unassigned.slice(0, 4).forEach((job) => { %>
        <button class="job-row" type="button" data-job-id="<%= job.id %>">
          <span class="job-row-main">
            <strong>#<%= job.id %></strong>
            <span><%= job.client %></span>
          </span>
          <span class="job-row-side"><%= job.city || "-" %></span>
        </button>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Geen open unassigned jobs.</p>
    <% } %>
  </div>

  <div class="queue-block">
    <h3><%= t("dashboard.queue.overdue", "Overdue") %></h3>
    <% if (queue.overdue.length) { %>
      <% queue.overdue.slice(0, 4).forEach((job) => { %>
        <button class="job-row danger" type="button" data-job-id="<%= job.id %>">
          <span class="job-row-main">
            <strong>#<%= job.id %></strong>
            <span><%= job.client %></span>
          </span>
          <span class="job-row-side"><%= job.city || "-" %></span>
        </button>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Geen overdue jobs.</p>
    <% } %>
  </div>

  <div class="queue-block">
    <h3><%= t("dashboard.queue.waiting_confirmation", "Waiting confirmation") %></h3>
    <% if (queue.waiting_confirmation.length) { %>
      <% queue.waiting_confirmation.slice(0, 4).forEach((job) => { %>
        <button class="job-row warning" type="button" data-job-id="<%= job.id %>">
          <span class="job-row-main">
            <strong>#<%= job.id %></strong>
            <span><%= job.client %></span>
          </span>
          <span class="job-row-side"><%= job.status %></span>
        </button>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Geen jobs in afwachting van bevestiging.</p>
    <% } %>
  </div>

  <div class="queue-block">
    <h3><%= t("dashboard.queue.missing_documents", "Missing documents") %></h3>
    <% if (queue.missing_documents.length) { %>
      <% queue.missing_documents.slice(0, 4).forEach((job) => { %>
        <button class="job-row info" type="button" data-job-id="<%= job.id %>">
          <span class="job-row-main">
            <strong>#<%= job.id %></strong>
            <span><%= job.client %></span>
          </span>
          <span class="job-row-side"><%= job.technician %></span>
        </button>
      <% }) %>
    <% } else { %>
      <p class="empty-state">Geen jobs met ontbrekende documenten.</p>
    <% } %>
  </div>
  </div>
</section>
