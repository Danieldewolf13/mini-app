<%
const layout = dashboardLayout || currentPreferences.dashboard;
const modulePartials = {
  queue: "./partials/action_queue",
  jobs: "./partials/active_jobs_list",
  technicians: "./partials/technicians_widget",
  appointments: "./partials/appointments_widget",
};

function renderWorkspaceModule(moduleKey, zoneClass) {
  if (!layout.visible[moduleKey]) {
    return "";
  }

  return `<div class="workspace-zone ${zoneClass} workspace-zone-${moduleKey}">${include(modulePartials[moduleKey])}</div>`;
}

const body = `
<div class="dashboard-page dashboard-canvas">
  <section class="dashboard-row dashboard-row-kpis">
    ${include("./partials/dashboard_kpis")}
  </section>

  <section class="dashboard-row dashboard-row-workspace">
    ${renderWorkspaceModule(layout.slots.left, "workspace-zone-left")}

    ${renderWorkspaceModule(layout.slots.center, "workspace-zone-center")}

    ${
      layout.visible.technicians || layout.visible.appointments
        ? `
          <div class="workspace-zone workspace-zone-side">
            ${layout.visible[layout.slots.sideTop] ? include(modulePartials[layout.slots.sideTop]) : ""}
            ${layout.visible[layout.slots.sideBottom] ? include(modulePartials[layout.slots.sideBottom]) : ""}
          </div>
        `
        : ``
    }
  </section>

  ${
    layout.visible.detail
      ? `
        <section class="dashboard-row dashboard-row-detail">
          <div class="detail-zone">
            ${include("./partials/job_detail_panel")}
          </div>
        </section>
      `
      : ``
  }

  ${
    layout.visible.map
      ? `
        <section class="panel map-card map-zone">
          <div class="section-head">
            <div>
              <p class="section-kicker">${t("dashboard.map.kicker", "Overview")}</p>
              <h2>${t("dashboard.map.title", "Mini map")}</h2>
            </div>
            <span class="section-meta">Regional overview only</span>
          </div>
          ${include("./partials/mini_map")}
        </section>
      `
      : ``
  }
</div>
`; %>
<%- include("../layout/base", { ...locals, body }) %>
