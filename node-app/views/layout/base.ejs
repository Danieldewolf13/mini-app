<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %> | mini app</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="/static/styles.css?v=ui-5">
  <% extraStyles.forEach((href) => { %>
    <link rel="stylesheet" href="<%= href %>">
  <% }) %>
</head>
<body>
  <div class="app-shell <%= rightPanel ? 'has-right-panel' : 'no-right-panel' %>">
    <aside class="sidebar">
      <%- include("../dispatcher/partials/sidebar") %>
    </aside>

    <div class="app-main">
      <header class="topbar">
        <%- include("../dispatcher/partials/topbar") %>
      </header>

      <main class="content <%= contentClass || '' %>">
        <% if (dbError) { %>
          <section class="alert-banner">
            <strong>Database melding</strong>
            <p><%= dbError %></p>
          </section>
        <% } %>

        <%- body %>
      </main>
    </div>

    <% if (rightPanel) { %>
      <aside class="right-panel">
        <%- include("../" + rightPanel) %>
      </aside>
    <% } %>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    window.MINI_APP_DATA = {
      jobs: <%- serialize(typeof jobs !== "undefined" ? jobs : []) %>,
      appointments: <%- serialize(typeof appointments !== "undefined" ? appointments : []) %>,
      technicians: <%- serialize(typeof technicians !== "undefined" ? technicians : []) %>,
      kpis: <%- serialize(typeof kpis !== "undefined" ? kpis : {}) %>,
      queue: <%- serialize(typeof queue !== "undefined" ? queue : {}) %>,
      filters: <%- serialize(typeof filters !== "undefined" ? filters : {}) %>,
      planningDate: <%- serialize(typeof planning_date !== "undefined" ? planning_date : "") %>,
      planningView: <%- serialize(typeof planning_view !== "undefined" ? planning_view : "day") %>,
      billitBaseUrl: <%- serialize(billitBaseUrl) %>,
      currentPath: <%- serialize(currentPath) %>,
      currentUser: <%- serialize(typeof currentUser !== "undefined" ? currentUser : null) %>,
      currentPreferences: <%- serialize(typeof currentPreferences !== "undefined" ? currentPreferences : null) %>,
      currentLanguage: <%- serialize(typeof currentPreferences !== "undefined" ? currentPreferences.language : "nl") %>
    };
  </script>
  <script src="/static/app.js?v=ui-5"></script>
  <script src="/static/jobs.js?v=ui-5"></script>
  <% extraScripts.forEach((src) => { %>
    <script src="<%= src %>"></script>
  <% }) %>
</body>
</html>
